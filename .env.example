# AI Career & Project Intelligence Platform

# === Supabase Auth ===
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_JWT_SECRET=your-jwt-secret-at-least-32-chars-long

# === Database ===
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/career_platform
DATABASE_URL_SYNC=postgresql://postgres:postgres@db:5432/career_platform
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=career_platform

# === Backend ===
BACKEND_SECRET_KEY=super-secret-key-change-in-production
BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# === OpenAI (optional — mock mode used when empty) ===
OPENAI_API_KEY=

# === GitHub (Phase 2 — optional) ===
GITHUB_TOKEN=

# === Stripe (Phase 3 — optional) ===
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# === Frontend ===
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
